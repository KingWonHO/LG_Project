# ============================================================
# 백엔드 환경 변수 예시. 복사해서 .env 로 만들고 값을 채우세요.
#   cp .env.example .env   (Windows: copy .env.example .env)
# ============================================================

# --- DB ---
DB_URL=sqlite:///data/app.db

# --- LLM: 로컬 Ollama (실제 사용 방식) ---
# 백엔드(src/llm_report.py)는 `ollama` 파이썬 패키지로 로컬 Ollama 데몬에 접속한다.
# 데몬 기본 주소: http://localhost:11434 (Ollama 설치 시 자동 실행)
# 사용 모델은 아래 LOCAL_LLM_MODEL 로 지정 (기본 gemma3:4b).
#   - Qwen 사용 시: LOCAL_LLM_MODEL=qwen2.5:3b  (그리고 `ollama pull qwen2.5:3b`)
LOCAL_LLM_MODEL=gemma3:4b
# 데몬이 다른 호스트/포트면 지정 (보통 불필요):
# OLLAMA_HOST=http://localhost:11434

# --- (현재 코드 미사용) 향후 vLLM 등 OpenAI 호환 서버 전환용 ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=not-needed-for-local
# LLM_MODEL=qwen2.5:3b

# --- 임베딩 (로컬, 한국어) ---
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# --- 벡터DB(Chroma) / 데이터 경로 ---
CHROMA_DIR=data/chroma
UPLOAD_DIR=data/uploads
REPORT_DIR=data/reports

# --- CORS (React dev 서버 허용) ---
CORS_ORIGINS=http://localhost:5173

# --- 접근 제어 (엔지니어 화면, ADM-001) ---
ENGINEER_ACCESS_CODE=change-me
