# ============================================================
# 백엔드 환경 변수 예시. 복사해서 .env 로 만들고 값을 채우세요.
#   cp .env.example .env   (Windows: copy .env.example .env)
# ============================================================

# --- DB ---
# SQLite(기본). PostgreSQL 전환 시:
#   DB_URL=postgresql+psycopg2://user:pass@db:5432/lgproject
DB_URL=sqlite:///data/app.db

# --- LLM: Qwen (로컬/사내 서버, OpenAI 호환 엔드포인트) ---
# vLLM/SGLang 등으로 Qwen 서빙 시 OpenAI 호환 base_url 사용.
# Ollama 사용 시: LLM_BASE_URL=http://localhost:11434/v1, LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=not-needed-for-local
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- 임베딩 (로컬, 한국어) ---
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask

# --- 벡터DB(Chroma) / 데이터 경로 ---
CHROMA_DIR=data/chroma
UPLOAD_DIR=data/uploads
REPORT_DIR=data/reports

# --- CORS (React dev 서버 허용) ---
CORS_ORIGINS=http://localhost:5173

# --- 접근 제어 (엔지니어 화면, ADM-001) ---
ENGINEER_ACCESS_CODE=change-me
